VITE_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=TU_SUPABASE_ANON_KEY
# Server only. Never expose this in VITE_* variables or frontend code.
SUPABASE_SERVICE_ROLE_KEY=TU_SUPABASE_SERVICE_ROLE_KEY

# Google Maps Platform
# Enable: Maps JavaScript API, Places API (New), Geocoding API
VITE_GOOGLE_MAPS_API_KEY=TU_GOOGLE_MAPS_BROWSER_KEY

# Local backend for Gemini/Supabase calls during development.
# Provider options:
# - developer: Gemini Developer API / AI Studio API key
# - vertex: Vertex AI on Google Cloud, using Cloud Run service account credentials
VITE_API_BASE_URL=http://127.0.0.1:8787
GEMINI_PROVIDER=developer
GEMINI_API_KEY=TU_GEMINI_SERVER_KEY
GEMINI_MODEL=gemini-2.5-flash

# Required only when GEMINI_PROVIDER=vertex.
GOOGLE_CLOUD_PROJECT=TU_GOOGLE_CLOUD_PROJECT_ID
GOOGLE_CLOUD_LOCATION=us-central1

# Server only. Password for the internal party admin panel.
PARTY_ADMIN_PASSWORD=CAMBIA_ESTA_CONTRASENA
